generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Poll {
  id          String   @id @default(uuid())
  category    String
  themeTitle  String
  productA    Json
  productB    Json
  curatorNote String?
  status      String   @default("PENDING")
  scheduledAt DateTime
  createdAt   DateTime @default(now())
  baseVotesA  Int      @default(0)
  baseVotesB  Int      @default(0)
  votes       Vote[]
}

model Vote {
  id        String   @id @default(uuid())
  pollId    String
  side      String
  createdAt DateTime @default(now())
  visitorId String   @default(uuid())
  poll      Poll     @relation(fields: [pollId], references: [id])

  @@unique([pollId, visitorId])
  @@index([pollId])
  @@index([visitorId])
  @@index([createdAt])
}

model TrendLog {
  id        String   @id @default(uuid())
  rawTrends String
  queries   Json
  createdAt DateTime @default(now())
}
