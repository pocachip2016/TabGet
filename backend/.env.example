DATABASE_URL=postgresql://tabget:tabget@localhost:5432/tabget

# LLM_PROVIDER: "ollama" (기본, 무료/로컬) | "gemini" (무료 API) | "openai"
LLM_PROVIDER=ollama

# Ollama — Docker 컨테이너 내부에서는 http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Gemini 모델 선택 (무료 티어 실측 한도 - Google AI Studio 대시보드 기준)
# gemini-2.5-flash-lite →  15 RPM / 1,000 RPD / 250K TPM  (권장: 여유로움)
# gemini-2.0-flash      →  15 RPM / 200 RPD / 1M TPM
# gemini-2.5-pro        →   5 RPM / 25 RPD / 250K TPM
# gemini-2.5-flash      →   5 RPM / 20 RPD / 250K TPM  (하루 ~1.8 run만 가능)
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_API_KEY=

# Gemini 쿼터 로그 (data/gemini.log)
# true: 로그 기록 + 콘솔 출력 | false: 비활성화
GEMINI_LOG=true

# OpenAI (LLM_PROVIDER=openai 일 때만 사용)
OPENAI_API_KEY=sk-...

SERPER_API_KEY=...
# USE_SERPER=true  → 실제 API 호출 (SERPER_DAILY_LIMIT 한도, 초과 시 캐시 폴백)
# USE_SERPER=false → 캐시 전용 (API 호출 없음)
USE_SERPER=true
# SERPER_DAILY_LIMIT: 하루 최대 API 호출 수 (기본값 10, Serper 무료 플랜 월 2,500회)
SERPER_DAILY_LIMIT=10
PORT=3000
MOCK_LLM=true
# 큐레이션 실행 주기 (cron, KST 기준) 기본: 매일 오전 9시
# 예) "0 9 * * *" → 매일 09:00 | "0 */6 * * *" → 6시간마다
CURATION_SCHEDULE=0 9 * * *
