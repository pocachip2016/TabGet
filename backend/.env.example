DATABASE_URL=postgresql://tabget:tabget@localhost:5432/tabget

# LLM_PROVIDER: "ollama" (기본, 무료/로컬) | "gemini" (무료 API) | "openai"
LLM_PROVIDER=ollama

# Ollama — Docker 컨테이너 내부에서는 http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Gemini 무료 티어: 15 RPM / 1,500 RPD / 1M TPM
# https://ai.google.dev/pricing
GEMINI_API_KEY=

# OpenAI (LLM_PROVIDER=openai 일 때만 사용)
OPENAI_API_KEY=sk-...

SERPER_API_KEY=...
# USE_SERPER=true  → 실제 API 호출 (SERPER_DAILY_LIMIT 한도, 초과 시 캐시 폴백)
# USE_SERPER=false → 캐시 전용 (API 호출 없음)
USE_SERPER=true
# SERPER_DAILY_LIMIT: 하루 최대 API 호출 수 (기본값 10, Serper 무료 플랜 월 2,500회)
SERPER_DAILY_LIMIT=10
PORT=3000
MOCK_LLM=true
# 큐레이션 실행 주기 (cron, KST 기준) 기본: 매일 오전 9시
# 예) "0 9 * * *" → 매일 09:00 | "0 */6 * * *" → 6시간마다
CURATION_SCHEDULE=0 9 * * *
